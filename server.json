  },
  "websiteUrl": "https://github.com/MukundaKatta/maskprompt-mcp",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@mukundakatta/maskprompt-mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
